# APSUSM Card Generator - Vercel Environment Variables

# Required for AI card generation and photo enhancement
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Override OpenAI model (defaults to dall-e-3)
# OPENAI_IMAGE_MODEL=dall-e-3

# Optional: Override template paths (defaults to templates/ folder)
# FRONT_TEMPLATE_PATH=/var/task/templates/CardFront.png
# CARD_EXAMPLE_PATH=/var/task/templates/CardExample.png
# BACK_TEMPLATE_PATH=/var/task/templates/CardBack.png

# Optional: Output directory for local development
# OUTPUT_DIR=/tmp/output

# Optional: Debug mode (set to "true" for verbose logging)
# DEBUG=false

# Notes for Vercel deployment:
# 1. Set OPENAI_API_KEY in Vercel dashboard under Environment Variables
# 2. Template files (CardFront.png, CardExample.png, CardBack.png) should be in card-generator/templates/
# 3. The serverless function automatically handles temporary file storage
# 4. Maximum function duration is set to 30 seconds (configurable in vercel.json)
# 5. File uploads are limited to 10MB per photo
